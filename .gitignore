
# ==========================================
# 1. QuantBot 3.0 核心数据与缓存 (Core Data)
# ==========================================
.quantbot_data/
*.tmp
backtest_log_*.jsonl

# 深度学习模型与二进制大文件全局防漏 (Global Safety Net)
*.pth
*.npz
*.pkl
*.feather
*.parquet

# 用户本地配置覆盖
quantbot_config.json

# ==========================================
# 2. 密钥与虚拟环境 (Security & Envs)
# ==========================================
venv/
env/
.env
.env.local

# ==========================================
# 3. Python 系统级缓存 (Python Caches)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ==========================================
# 4. 业务日志与通用产物 (Logs & Artifacts)
# ==========================================
logs/
*.csv
*.db
*.sqlite3
*.log
output_images/
output_videos/

# ==========================================
# 5. 操作系统与 IDE 缓存 (OS & IDE)
# ==========================================
.DS_Store
.vscode/
.idea/
*.swp
